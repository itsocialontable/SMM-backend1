# ==========================================
# .env.example
# SECURITY NOTICE (v18): The original .env.example shipped with this
# project contained REAL, LIVE production credentials (MongoDB password,
# JWT secret, encryption key, Gmail app password, Redis token, OAuth
# client secrets, Cloudinary keys). That is a serious security exposure.
#
# >>> If those values were ever committed to git or shared anywhere,
# >>> ROTATE ALL OF THEM IMMEDIATELY (MongoDB user password, JWT_SECRET,
# >>> SECRET_KEY, Gmail app password, Redis token, every OAuth client
# >>> secret, Cloudinary API secret) before deploying this project.
#
# This file now only contains placeholders. Fill in YOUR OWN real
# values in a local .env file (never commit .env to git).
# ==========================================

PORT=5000
FRONTEND_URL=http://localhost:8080

# CORS: comma-separated list of every domain your frontend runs on
# (production domain, staging domain, current ngrok URL, teammates'
# LAN IPs, etc). Any origin NOT in this list (and not equal to
# FRONTEND_URL) will be blocked by the browser with a CORS error —
# if a device shows blank data after login, check this first.
# Example: ALLOWED_ORIGINS=https://app.mydomain.com,https://staging.mydomain.com,https://abcd1234.ngrok-free.app
ALLOWED_ORIGINS=

# MongoDB Atlas (or any MongoDB) connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/smm-backend?retryWrites=true&w=majority

# Strong random secret for signing JWTs — generate with: openssl rand -hex 32
JWT_SECRET=replace_with_a_long_random_string

# Used to encrypt/decrypt OAuth tokens stored in SocialAccount — generate with: openssl rand -hex 32
SECRET_KEY=replace_with_a_long_random_string

# Email (Nodemailer / Gmail SMTP) — use a Gmail "App Password", not your normal password
# Emails now send via Resend (HTTP API) instead of Gmail SMTP — Gmail
# SMTP gets blocked on Render's free tier and many other hosts.
# 1. Sign up free at https://resend.com
# 2. Create an API key -> paste below
# 3. RESEND_FROM_EMAIL: use "onboarding@resend.dev" for quick testing,
#    or "YourName <you@yourdomain.com>" once you verify your own domain
#    in Resend (needed before you can email non-test addresses reliably).
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=Growth Craft 360 <onboarding@resend.dev>

# Redis (for BullMQ post scheduling). Local: redis://127.0.0.1:6379
# Hosted (e.g. Upstash): rediss://default:<token>@<host>:<port>
REDIS_URL=redis://127.0.0.1:6379

# ================= FACEBOOK / INSTAGRAM =================
# Meta App: needs pages_show_list, pages_manage_posts, pages_read_engagement
# (Facebook) and instagram_basic, instagram_content_publish (Instagram)
# approved via Meta App Review for production posting.
FB_CLIENT_ID=
FB_CLIENT_SECRET=
FB_REDIRECT_URI=https://your-domain.com/auth/callback

INSTAGRAM_LOGIN_CLIENT_ID=
INSTAGRAM_LOGIN_CLIENT_SECRET=
INSTAGRAM_LOGIN_REDIRECT_URI=https://your-domain.com/auth/callback


# ================= TWITTER / X =================
# Twitter app needs OAuth2 with offline.access scope for refresh tokens
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URI=https://your-domain.com/auth/callback

# ================= LINKEDIN =================
# LinkedIn app needs w_member_social scope approved for posting
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=https://your-domain.com/auth/callback

# ================= YOUTUBE / GOOGLE =================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-domain.com/auth/callback

# ================= PINTEREST =================
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
PINTEREST_REDIRECT_URI=https://your-domain.com/auth/callback

THREADS_CLIENT_ID=
THREADS_CLIENT_SECRET=
THREADS_REDIRECT_URI=https://smm-backend1-stkn.onrender.com/auth/callback

# ================= CLOUDINARY =================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
